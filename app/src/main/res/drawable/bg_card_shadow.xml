<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Lớp bóng ngoài cùng (rất mờ) -->
    <item android:left="2dp" android:top="4dp" android:right="2dp" android:bottom="6dp">
        <shape>
            <solid android:color="#05000000" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <!-- Lớp bóng chính -->
    <item android:left="1dp" android:top="2dp" android:right="1dp" android:bottom="4dp">
        <shape>
            <solid android:color="#0D000000" />
            <corners android:radius="17dp" />
        </shape>
    </item>
    <!-- Nội dung chính -->
    <item android:bottom="4dp">
        <shape>
            <solid android:color="@color/white" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>