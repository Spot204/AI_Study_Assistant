<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="#F3F4F6" app:cardCornerRadius="20dp"
    app:cardElevation="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/cv_deck_icon_bg"
            android:layout_width="60dp"
            android:layout_height="60dp"
            app:cardBackgroundColor="#7C4DFF" app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/iv_deck_icon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_deck_book"
                android:contentDescription="Icon môn học"
                app:tint="#FFFFFF" /> </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tv_deck_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Toán cao cấp A1"            android:textColor="#111827" android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/cv_deck_icon_bg"
            app:layout_constraintTop_toTopOf="@+id/cv_deck_icon_bg" />

        <TextView
            android:id="@+id/tv_deck_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            tools:text="45 thẻ"
            android:textColor="#4B5563" android:textSize="14sp"
            app:layout_constraintStart_toStartOf="@+id/tv_deck_title"
            app:layout_constraintTop_toBottomOf="@+id/tv_deck_title" />

        <ProgressBar
            android:id="@+id/pb_deck_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:max="100"
            tools:progress="75"
            android:progressDrawable="@drawable/progress_custom" app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/tv_deck_progress_text"
            app:layout_constraintStart_toStartOf="@+id/tv_deck_count"
            app:layout_constraintTop_toBottomOf="@+id/tv_deck_count" />

        <TextView
            android:id="@+id/tv_deck_progress_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="75%"
            android:textColor="#4B5563" android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@+id/pb_deck_progress"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/pb_deck_progress" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>