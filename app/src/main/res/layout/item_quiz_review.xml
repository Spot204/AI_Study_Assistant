<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:layout_marginHorizontal="2dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <EditText
                android:id="@+id/et_quiz_question"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:backgroundTint="#E5E7EB"
                android:hint="Câu hỏi Quiz"
                android:textColor="#1F2937"
                android:textColorHint="#9CA3AF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:inputType="textMultiLine"
                app:layout_constraintEnd_toStartOf="@+id/btn_quiz_delete"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageButton
                android:id="@+id/btn_quiz_delete"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="@android:color/transparent" app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="#EF4444" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <EditText
            android:id="@+id/et_quiz_opt1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="#F3F4F6"
            android:hint="Lựa chọn A"
            android:textColor="#4B5563"
            android:textColorHint="#9CA3AF"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/et_quiz_opt2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:backgroundTint="#F3F4F6"
            android:hint="Lựa chọn B"
            android:textColor="#4B5563"
            android:textColorHint="#9CA3AF"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/et_quiz_opt3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:backgroundTint="#F3F4F6"
            android:hint="Lựa chọn C"
            android:textColor="#4B5563"
            android:textColorHint="#9CA3AF"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/et_quiz_opt4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:backgroundTint="#F3F4F6"
            android:hint="Lựa chọn D"
            android:textColor="#4B5563"
            android:textColorHint="#9CA3AF"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/et_quiz_correct"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="#10B981"
            android:hint="Đáp án đúng (Điền: 1, 2, 3 hoặc 4)"
            android:inputType="number"
            android:textColor="#10B981"
            android:textColorHint="#9CA3AF"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>
</androidx.cardview.widget.CardView>