<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="114dp"
        android:background="@color/white"
        android:paddingTop="40dp"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Title -->

        <!-- Add Button Container -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/schedule_title"
            android:textColor="@color/text_primary"
            style="@style/AppTextAppearance.Title" />

        <FrameLayout
            android:id="@+id/btnAddTask"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_circle_white"
            android:clickable="true"
            android:elevation="2dp"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@string/desc_add_schedule"
                android:src="@android:drawable/ic_input_add"
                app:tint="@color/purple_primary" />

        </FrameLayout>

    </LinearLayout>
    <!-- CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- CALENDAR CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="28dp"
                app:cardElevation="4dp"
                app:cardUseCompatPadding="true"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Month Selection -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_circle_white"
                            android:elevation="2dp"
                            android:padding="12dp"
                            android:src="@android:drawable/ic_media_previous"
                            android:contentDescription="@string/desc_prev_month"
                            android:clickable="true"
                            android:focusable="true"
                            app:tint="@color/text_primary"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Tháng 5 năm 2026"
                            android:textColor="@color/text_primary"
                            style="@style/AppTextAppearance.TitleMedium" />

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_circle_white"
                            android:elevation="2dp"
                            android:padding="12dp"
                            android:src="@android:drawable/ic_media_next"
                            android:contentDescription="@string/desc_next_month"
                            android:clickable="true"
                            android:focusable="true"
                            app:tint="@color/text_primary"/>

                    </LinearLayout>

                    <!-- Days Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <!-- CN -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CN"
                                android:textColor="@color/text_secondary"
                                style="@style/AppTextAppearance.BodySmall" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="17"
                                android:textColor="@color/text_primary"
                                style="@style/AppTextAppearance.BodyLarge"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- T2 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="T2"
                                android:textColor="@color/text_secondary"
                                style="@style/AppTextAppearance.BodySmall" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="18"
                                android:textColor="@color/text_primary"
                                style="@style/AppTextAppearance.BodyLarge"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- T3 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="T3"
                                android:textColor="@color/text_secondary"
                                style="@style/AppTextAppearance.BodySmall" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="19"
                                android:textColor="@color/text_primary"
                                style="@style/AppTextAppearance.BodyLarge"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Selected T4 -->
                        <FrameLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1">
                            <LinearLayout
                                android:layout_width="54dp"
                                android:layout_height="54dp"
                                android:layout_gravity="center"
                                android:background="@drawable/bg_selected_day"
                                android:gravity="center"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="T4"
                                    android:textColor="@android:color/white"
                                    style="@style/AppTextAppearance.BodySmall" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="20"
                                    android:textColor="@android:color/white"
                                    style="@style/AppTextAppearance.BodyLarge"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </FrameLayout>

                        <!-- T5 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="T5"
                                android:textColor="@color/text_secondary"
                                style="@style/AppTextAppearance.BodySmall" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="21"
                                android:textColor="@color/text_primary"
                                style="@style/AppTextAppearance.BodyLarge"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- T6 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="T6"
                                android:textColor="@color/text_secondary"
                                style="@style/AppTextAppearance.BodySmall" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="22"
                                android:textColor="@color/text_primary"
                                style="@style/AppTextAppearance.BodyLarge"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- T7 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="T7"
                                android:textColor="@color/text_secondary"
                                style="@style/AppTextAppearance.BodySmall" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="23"
                                android:textColor="@color/text_primary"
                                style="@style/AppTextAppearance.BodyLarge"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- TODAY SECTION HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"

                android:layout_marginBottom="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/schedule_today_title"
                    android:textColor="@color/text_primary"
                    style="@style/AppTextAppearance.Title" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/schedule_task_count"
                    android:textColor="@color/text_secondary"
                    style="@style/AppTextAppearance.Body" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTasks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>