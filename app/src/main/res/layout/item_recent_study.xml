<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E2E8F0">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Icon representing the study type -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivTypeIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:background="#F1F5F9"
            android:src="@drawable/ic_book"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvRecentSubject"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:text="Tên bài học"
            android:textColor="#1E293B"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/tvProgressPercent"
            app:layout_constraintStart_toEndOf="@id/ivTypeIcon"
            app:layout_constraintTop_toTopOf="@id/ivTypeIcon"
            tools:text="Cấu trúc dữ liệu" />

        <TextView
            android:id="@+id/tvRecentDetails"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Loại • Thời gian"
            android:textColor="#64748B"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="@id/tvRecentSubject"
            app:layout_constraintStart_toStartOf="@id/tvRecentSubject"
            app:layout_constraintTop_toBottomOf="@id/tvRecentSubject"
            tools:text="Trắc nghiệm • 15 phút" />

        <TextView
            android:id="@+id/tvProgressPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textColor="#6366F1"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/tvRecentSubject"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvRecentSubject"
            tools:text="85%" />

        <ProgressBar
            android:id="@+id/pbRecentProgress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:layout_marginTop="16dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/progress_custom"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivTypeIcon" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
