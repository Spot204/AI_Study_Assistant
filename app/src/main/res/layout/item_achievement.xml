<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="140dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_rounded_card"
    android:orientation="vertical"
    android:padding="12dp"
    android:layout_marginEnd="12dp">

    <FrameLayout
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_achievement_unlocked">
        <ImageView
            android:id="@+id/iv_achievement_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_trophy"
            app:tint="@color/chart_3" />
    </FrameLayout>

    <TextView
        android:id="@+id/tv_achievement_title"
        style="@style/AppTextAppearance.BodySmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Title"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tv_achievement_description"
        style="@style/AppTextAppearance.Caption"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Description"
        android:textColor="@color/text_secondary" />
</LinearLayout>
