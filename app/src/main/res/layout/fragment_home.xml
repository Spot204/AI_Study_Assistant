<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header: Chào hỏi & Avatar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true">

                <TextView
                    android:id="@+id/tvWelcomeHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chào bạn!"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#1E293B" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hôm nay bạn muốn học gì nào? 🚀"
                    android:textSize="14sp"
                    android:textColor="#64748B"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivUserAvatar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:src="@drawable/ic_user"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/CircleImage"
                android:padding="2dp"
                android:background="#E2E8F0" />
        </RelativeLayout>

        <!-- Section: Mục tiêu học tập -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mục tiêu hàng ngày"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1E293B" />

                    <TextView
                        android:id="@+id/btnChangeGoal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="Thay đổi"
                        android:textColor="#6366F1"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:clickable="true"
                        android:focusable="true" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/tvGoalProgressText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 / 5 phút đã hoàn thành"
                    android:textSize="14sp"
                    android:textColor="#64748B"
                    android:layout_marginTop="12dp" />

                <ProgressBar
                    android:id="@+id/pbGoalProgress"
                    style="@android:style/Widget.Material.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="8dp"
                    android:progress="60"
                    android:progressTint="#6366F1"
                    android:progressBackgroundTint="#E2E8F0" />

                <!-- Login Tracker (Dãy ngày trong tuần) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:gravity="center">
                    <TextView android:id="@+id/dotMon" android:layout_width="28dp" android:layout_height="28dp" android:text="T2" android:textSize="10sp" android:gravity="center" android:background="@drawable/bg_circle_active" android:textColor="#FFF" android:layout_margin="4dp"/>
                    <TextView android:id="@+id/dotTue" android:layout_width="28dp" android:layout_height="28dp" android:text="T3" android:textSize="10sp" android:gravity="center" android:background="@drawable/bg_circle_active" android:textColor="#FFF" android:layout_margin="4dp"/>
                    <TextView android:id="@+id/dotWed" android:layout_width="28dp" android:layout_height="28dp" android:text="T4" android:textSize="10sp" android:gravity="center" android:background="@drawable/bg_circle_active" android:textColor="#FFF" android:layout_margin="4dp"/>
                    <TextView android:id="@+id/dotThu" android:layout_width="28dp" android:layout_height="28dp" android:text="T5" android:textSize="10sp" android:gravity="center" android:background="@drawable/bg_circle_inactive" android:textColor="#64748B" android:layout_margin="4dp"/>
                    <TextView android:id="@+id/dotFri" android:layout_width="28dp" android:layout_height="28dp" android:text="T6" android:textSize="10sp" android:gravity="center" android:background="@drawable/bg_circle_inactive" android:textColor="#64748B" android:layout_margin="4dp"/>
                    <TextView android:id="@+id/dotSat" android:layout_width="28dp" android:layout_height="28dp" android:text="T7" android:textSize="10sp" android:gravity="center" android:background="@drawable/bg_circle_inactive" android:textColor="#64748B" android:layout_margin="4dp"/>
                    <TextView android:id="@+id/dotSun" android:layout_width="28dp" android:layout_height="28dp" android:text="CN" android:textSize="10sp" android:gravity="center" android:background="@drawable/bg_circle_inactive" android:textColor="#64748B" android:layout_margin="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔥 Chuỗi"
                            android:textSize="12sp"
                            android:textColor="#94A3B8" />
                        <TextView
                            android:id="@+id/tvStreakCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="7 ngày"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#F59E0B" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⏱ Hôm nay"
                            android:textSize="12sp"
                            android:textColor="#94A3B8" />
                        <TextView
                            android:id="@+id/tvStudyTimeDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 phút"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#10B981" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Daily Advice Section -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#EEF2FF"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/tvAdviceCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡 LỜI KHUYÊN HÔM NAY"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#4F46E5"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvDailyTipText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Đang lấy lời khuyên cho bạn..."
                    android:textSize="14sp"
                    android:textColor="#374151"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Continue Learning Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tiếp tục học"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1E293B"
            android:layout_marginBottom="12dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRecentStudy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            tools:listitem="@layout/item_recent_study" />

        <!-- Recommendations -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đề xuất cho bạn"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1E293B"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:layout_width="160dp"
                    android:layout_height="110dp"
                    android:layout_marginEnd="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#F0FDF4">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🏆"
                            android:textSize="28sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thử thách Tuần"
                            android:textStyle="bold"
                            android:textColor="#166534"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="160dp"
                    android:layout_height="110dp"
                    android:layout_marginEnd="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFF7ED">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🤖"
                            android:textSize="28sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AI Tutor 24/7"
                            android:textStyle="bold"
                            android:textColor="#9A3412"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="160dp"
                    android:layout_height="110dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#F5F3FF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📊"
                            android:textSize="28sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Báo cáo học tập"
                            android:textStyle="bold"
                            android:textColor="#5B21B6"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </HorizontalScrollView>

        <View
            android:layout_width="match_parent"
            android:layout_height="100dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
