<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0B10">

    <ImageButton
        android:id="@+id/btn_ocr_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_circle_gradient"
        android:src="@drawable/ic_arrow_left"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#FFFFFF" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="OCR &amp; Tóm tắt AI"
        android:textColor="#FFFFFF"
        style="@style/AppTextAppearance.TitleMedium"
        app:layout_constraintBottom_toBottomOf="@+id/btn_ocr_back"
        app:layout_constraintStart_toEndOf="@+id/btn_ocr_back"
        app:layout_constraintTop_toTopOf="@+id/btn_ocr_back" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cv_ocr_capture"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:layout_margin="20dp"
        app:cardBackgroundColor="#161824"
        app:cardCornerRadius="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_ocr_back">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_camera"
                app:tint="#7C4DFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Chụp ảnh hoặc tải lên tài liệu"
                android:textColor="#FFFFFF"
                style="@style/AppTextAppearance.BodyMedium" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tv_ocr_result_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        android:text="Kết quả tóm tắt"
        android:textColor="#FFFFFF"
        style="@style/AppTextAppearance.BodyLarge"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cv_ocr_capture" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="20dp"
        android:background="@drawable/bg_input_field"
        android:padding="16dp"
        app:layout_constraintBottom_toTopOf="@+id/btn_generate_flashcards"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_ocr_result_label">

        <TextView
            android:id="@+id/tv_ocr_summary_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kết quả tóm tắt sẽ hiển thị ở đây sau khi AI xử lý..."
            android:textColor="#8A8D9F"
            style="@style/AppTextAppearance.BodySmall"
            android:lineSpacingExtra="4dp"/>
    </androidx.core.widget.NestedScrollView>

    <Button
        android:id="@+id/btn_generate_flashcards"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_margin="20dp"
        android:backgroundTint="#7C4DFF"
        android:text="Tạo Flashcards từ tóm tắt"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        style="@style/AppTextAppearance.BodyMedium"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ProgressBar
        android:id="@+id/pb_ocr_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
