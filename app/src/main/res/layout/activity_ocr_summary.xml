<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="#FFFFFF">

    <ImageButton
        android:id="@+id/btn_ocr_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:src="@drawable/ic_arrow_left"
        android:background="@android:color/transparent" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#1F2937" />

    <TextView
        android:id="@+id/tv_title_screen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Xem trước &amp; Sửa bộ thẻ"
        android:textColor="#1F2937"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btn_ocr_back"
        app:layout_constraintStart_toEndOf="@+id/btn_ocr_back"
        app:layout_constraintTop_toTopOf="@+id/btn_ocr_back" />

    <EditText
        android:id="@+id/et_ocr_title"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:layout_margin="20dp"
        android:background="@android:drawable/edit_text"
        android:backgroundTint="#F3F4F6"
        android:hint="Nhập tên bộ thẻ (Hoặc để AI tự đặt tên)"
        android:inputType="textCapSentences"
        android:maxLines="1"
        android:paddingHorizontal="16dp"
        android:textColor="#1F2937"
        android:textColorHint="#9CA3AF"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_ocr_back" />

    <TextView
        android:id="@+id/tv_ocr_result_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="16dp"
        android:text="Danh sách thẻ do AI tạo"
        android:textColor="#4B5563"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/et_ocr_title" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_flashcard_review"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toTopOf="@+id/btn_generate_flashcards"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_ocr_result_label"
        tools:listitem="@layout/item_flashcard_review"
        />


    <Button
        android:id="@+id/btn_generate_flashcards"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_margin="20dp"
        android:backgroundTint="#7C4DFF"
        android:text="Lưu bộ thẻ vào máy"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ProgressBar
        android:id="@+id/pb_ocr_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminateTint="#7C4DFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>