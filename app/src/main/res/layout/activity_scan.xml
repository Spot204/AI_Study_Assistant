<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF8F6">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Scan &amp; Summarize"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:layout_marginBottom="16dp" />

        <!-- Khung ảnh bo góc cho Máy ảnh -->
        <CardView
            android:layout_width="match_parent"
            android:layout_height="250dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#F3F2F5"
            android:foreground="?android:attr/selectableItemBackground">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/imgThumbnail"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_centerInParent="true"
                    android:src="@drawable/ic_camera_placeholder" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/imgThumbnail"
                    android:layout_centerHorizontal="true"
                    android:text="Đặt tài liệu học tập của bạn vào khung hình"
                    android:textColor="#777777"
                    android:layout_marginTop="12dp"/>
            </RelativeLayout>
        </CardView>

        <!-- Nhập thủ công hoặc dán văn bản -->
        <EditText
            android:id="@+id/edtManualNotes"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@drawable/bg_input_field"
            android:layout_marginTop="16dp"
            android:hint="Hoặc dán văn bản, ghi chú của bạn vào đây..."
            android:gravity="top|left"
            android:padding="12dp"
            android:textSize="14sp" />

        <!-- Nút Chụp Ảnh và Nút Phân Tích -->
        <Button
            android:id="@+id/btnTakePhoto"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_gradient_button"
            android:text="Chụp ảnh tài liệu"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnProcessText"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="#0C84FF"
            android:text="Quét &amp; Tóm tắt AI"
            android:textColor="#FFFFFF" />

        <ProgressBar
            android:id="@+id/progressBarScanner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

        <!-- Kết quả bóc tách từ AI -->
        <LinearLayout
            android:id="@+id/layoutAiResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kết quả Phân Tích AI"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#8A22F2"/>

            <TextView
                android:id="@+id/tvSummaryResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="#333333" />

            <TextView
                android:id="@+id/tvVocabularyCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#00AA55"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvFlashcardCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#0C84FF"
                android:textStyle="bold" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>