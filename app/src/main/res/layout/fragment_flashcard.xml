<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="40dp"
    android:background="#FFFFFF"
    android:padding="20dp">

    <TextView
        android:id="@+id/tv_fc_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Flashcards"
        android:textColor="#111827"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btn_fc_add"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_circle_gradient"
        android:src="@drawable/ic_add"
        android:contentDescription="Thêm mới"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#111827" />

    <EditText
        android:id="@+id/et_fc_search"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_input_field"
        android:drawableStart="@drawable/ic_search"
        android:drawablePadding="12dp"
        android:hint="Tìm kiếm bộ thẻ..."
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="#111827"
        android:textColorHint="#6B7280"
        android:textSize="15sp"
        android:inputType="text"
        android:importantForAutofill="no"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_fc_title" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_fc_ai_banner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_gradient_banner"
        android:padding="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/et_fc_search">

        <ImageView
            android:id="@+id/iv_fc_ai_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_sparkle"
            android:contentDescription="AI Icon"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_fc_ai_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:text="Tạo Flashcard với AI"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/btn_fc_ai_create"
            app:layout_constraintStart_toEndOf="@+id/iv_fc_ai_icon"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_fc_ai_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Upload tài liệu để tạo tự động"
            android:textColor="#E5E7EB"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="@+id/tv_fc_ai_title"
            app:layout_constraintStart_toStartOf="@+id/tv_fc_ai_title"
            app:layout_constraintTop_toBottomOf="@+id/tv_fc_ai_title" />

        <Button
            android:id="@+id/btn_fc_ai_create"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#7C4DFF"
            android:text="Tạo mới"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            app:cornerRadius="20dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/tv_fc_section_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="Bộ thẻ của bạn"
        android:textColor="#111827"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layout_fc_ai_banner" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_fc_decks"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_fc_section_title"
        tools:listitem="@layout/item_flashcard_deck" />

</androidx.constraintlayout.widget.ConstraintLayout>